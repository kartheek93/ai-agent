# Copy this file to .env at the repo root and fill in the values you want to use.

# Optional local database override
# ASSISTANT_DB_PATH=data/assistant.db

# Optional Vertex AI / Gemini setup
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=global
VERTEX_GEMINI_MODEL=gemini-2.5-flash

# Choose one authentication path:
# 1. Preferred for local development: `gcloud auth login` and `gcloud config set project ...`
# 2. Optional explicit token. This expires, so it is usually less convenient than gcloud auth.
# VERTEX_ACCESS_TOKEN=

# Optional explicit gcloud path if it is not available on PATH.
# GCLOUD_BINARY=C:\Program Files\Google\Cloud SDK\google-cloud-sdk\bin\gcloud.cmd

# Optional Google Workspace OAuth setup
# Install the optional dependencies first:
#   pip install -e ".[google-workspace]"
#
# 1. Enable Google Calendar API, Google Tasks API, and Gmail API in your GCP project.
# 2. Configure the OAuth consent screen.
# 3. Create a Desktop app OAuth client.
# 4. Download the client JSON and point OAUTH_JSON_PATH at it.
#
# OAUTH_JSON_PATH=C:\Users\Karthik\Downloads\client_secret_xxx.json
# GOOGLE_TOKEN_PATH=data\google_token.json
# GMAIL_MODE=send-only
# GOOGLE_CALENDAR_ID=primary
# GOOGLE_TASKS_LIST_ID=
# GOOGLE_GMAIL_USER_ID=me
